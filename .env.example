# Database
DATABASE_URL=file:./data/rudder.db

# Session
SESSION_SECRET=<generate-random-64-character-string>
SESSION_MAX_AGE=604800

# Encryption (for sensitive data like SSH keys, API keys)
ENCRYPTION_KEY=<generate-random-32-character-string>

# Public URL (used for OIDC redirect URIs and provisioning scripts)
PUBLIC_URL=http://localhost:5173

# Origin for SvelteKit CSRF protection — must match the URL clients use to reach the app.
# In production set this to your actual domain, e.g. https://rudder.example.com
ORIGIN=http://localhost:3000

# Worker Registration (optional - required for worker self-registration)
WORKER_REGISTRATION_SECRET=<generate-random-32-character-string>

# Seed Token (optional - for initial admin user creation via API)
SEED_TOKEN=<generate-random-32-character-string>

# OIDC Providers (optional)
# Google
# OIDC_GOOGLE_CLIENT_ID=
# OIDC_GOOGLE_CLIENT_SECRET=

# GitHub
# OIDC_GITHUB_CLIENT_ID=
# OIDC_GITHUB_CLIENT_SECRET=

# Okta
# OIDC_OKTA_CLIENT_ID=
# OIDC_OKTA_CLIENT_SECRET=
# OIDC_OKTA_DOMAIN=

# Auth0
# OIDC_AUTH0_CLIENT_ID=
# OIDC_AUTH0_CLIENT_SECRET=
# OIDC_AUTH0_DOMAIN=
